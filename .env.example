DATABASE_URL=postgresql+asyncpg://studio:studio@localhost:5437/studio
JWT_SECRET=change-me-to-a-long-random-string
APP_TIMEZONE=Asia/Seoul
STORAGE_BACKEND=local
STORAGE_PATH=./storage
LOG_DIR=D:/workspace/ok2020/log/studio
CORS_ORIGINS=["http://localhost:5173"]
SECURE_COOKIES=false
LOG_SQL=false
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# 로컬 개발 시 키 없이 쓰려면 SCRIPT_PROVIDER=fake 로 바꾸세요.
SCRIPT_PROVIDER=openai
VOICE_PROVIDER=edge_tts
CAPTIONS_PROVIDER=whisper
# whisper 모델 크기: tiny|base|small|medium (클수록 정확하고 느리다)
WHISPER_MODEL=small
